{
  "name": "smart-transport-operations-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5050",
    "build": "prisma generate && next build",
    "start": "next start -p 5050",
    "lint": "biome lint src",
