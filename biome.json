{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "files": {
        "includes": [
            "**",
            "!**/*.css"
        ]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "style": {
                "noNonNullAssertion": "warn"
            },
            "suspicious": {
                "noExplicitAny": "error"
            },
            "correctness": {
                "noUnusedVariables": "error"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "formatWithErrors": false,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single"
        }
    }
}
