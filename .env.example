# TransitOps Environment Variables Template

# 1. Server Configuration
PORT=5050
NODE_ENV=development

# 2. Database (SQLite default)
DATABASE_URL="file:./dev.db"

# 3. Custom JWT Authentication Secrets
JWT_ACCESS_SECRET="transitops-access-secret-key-12345!"
JWT_REFRESH_SECRET="transitops-refresh-secret-key-12345!"

# 4. AES-256-GCM Cryptographic Key (Used for encrypting Driver PII in SQLite)
# Must be a secure random 32-character string or hashable value
ENCRYPTION_KEY="transitops-encryption-key-3char"
